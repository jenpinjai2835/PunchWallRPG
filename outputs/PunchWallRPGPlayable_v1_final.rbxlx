			<Item class="LocalScript" referent="RBXC8E18E3826D042B2BDF9CD5B59AB850C">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
