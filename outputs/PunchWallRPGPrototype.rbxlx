		power = 45,
		pos = Vector3.new(55, 9, -27),
		color = Color3.fromRGB(97, 109, 122),
		material = Enum.Material.Metal,
	},
	{
		name = "Crystal Wall",
		hp = 42000,
		level = 16,
		coins = 5200,
		power = 230,
		pos = Vector3.new(88, 10, -27),
		color = Color3.fromRGB(88, 220, 245),
		material = Enum.Material.Glass,
	},
	{
		name = "Lava Wall",
		hp = 220000,
		level = 30,
		coins = 28000,
		power = 1100,
		pos = Vector3.new(124, 11, -27),
		color = Color3.fromRGB(255, 96, 45),
		material = Enum.Material.Neon,
	},
	{
		name = "Cyber Gate",
		hp = 1200000,
		level = 48,
		coins = 160000,
		power = 5500,
		pos = Vector3.new(164, 12, -27),
		color = Color3.fromRGB(75, 115, 255),
		material = Enum.Material.ForceField,
	},
}

local function updateWallText(wall)
	local sign = wall:FindFirstChild("Sign")
	if not sign then
		return
	end
	local title = sign:FindFirstChild("Title")
	local subtitle = sign:FindFirstChild("Subtitle")
	local hp = wall:GetAttribute("HP") or 0
	local maxHp = wall:GetAttribute("MaxHP") or 1
	if title then
		title.Text = wall.Name
	end
	if subtitle then
		subtitle.Text = ("HP %s/%s | Lv %d"):format(formatNumber(hp), formatNumber(maxHp), wall:GetAttribute("RequiredLevel") or 1)
	end
end

local function buildWall(config)
	local wall = makePart(config.name, wallsFolder, Vector3.new(18, 14 + config.level * 0.12, 4), config.pos, config.color, config.material)
	wall:SetAttribute("MaxHP", config.hp)
	wall:SetAttribute("HP", config.hp)
	wall:SetAttribute("RequiredLevel", config.level)
	wall:SetAttribute("CoinReward", config.coins)
	wall:SetAttribute("PowerReward", config.power)
	makeText(wall, config.name, "", Enum.NormalId.Front)
	updateWallText(wall)

	local clickDetector = Instance.new("ClickDetector")
	clickDetector.MaxActivationDistance = 34
	clickDetector.Parent = wall

	clickDetector.MouseClick:Connect(function(player)
		local now = os.clock()
		local lastHit = player:GetAttribute("LastWallHit") or 0
		local cooldown = math.max(0.08, WALL_HIT_COOLDOWN / math.max(statValue(player, "BreakSpeed", 1), 1))
		if now - lastHit < cooldown then
			return
		end
		player:SetAttribute("LastWallHit", now)

		local required = wall:GetAttribute("RequiredLevel") or 1
		if statValue(player, "WallLevel", 1) < required then
			notify(player, ("Need Wall Level %d for %s."):format(required, wall.Name), Color3.fromRGB(255, 120, 120))
			return
		end

		local power = statValue(player, "Power", 1)
		local fist = statValue(player, "FistMultiplier", 1)
		local pet = statValue(player, "PetMultiplier", 0)
		local rebirth = 1 + statValue(player, "Rebirths", 0) * 0.25
		local damage = power * fist * (1 + pet) * rebirth
		local critChance = statValue(player, "CritChance", 0)
		if math.random(1, 100) <= critChance then
			damage *= 2
			notify(player, "Critical punch! x2 damage", Color3.fromRGB(255, 236, 94))
		end

		wall:SetAttribute("HP", math.max(0, (wall:GetAttribute("HP") or 0) - damage))
		updateWallText(wall)

		local pulse = TweenService:Create(wall, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Size = wall.Size + Vector3.new(0.4, 0.4, 0.08) })
		pulse:Play()
		pulse.Completed:Once(function()
			if wall.Parent then
				TweenService:Create(wall, TweenInfo.new(0.1), { Size = Vector3.new(18, 14 + required * 0.12, 4) }):Play()
			end
		end)

		if wall:GetAttribute("HP") <= 0 and not wall:GetAttribute("Broken") then
			wall:SetAttribute("Broken", true)
			local reward = wall:GetAttribute("CoinReward") or 0
			local powerReward = wall:GetAttribute("PowerReward") or 0
			addStat(player, "Coins", reward)
			addStat(player, "Power", powerReward)
			addStat(player, "FistMastery", 0.35)
			if required >= statValue(player, "WallLevel", 1) then
				addStat(player, "WallLevel", 1)
			end
			notify(player, ("Broke %s! +%s coins, +%s power"):format(wall.Name, formatNumber(reward), formatNumber(powerReward)), Color3.fromRGB(104, 255, 169))

			wall.Transparency = 0.78
			wall.CanCollide = false
			task.delay(WALL_RESPAWN_SECONDS, function()
				if wall.Parent then
					wall:SetAttribute("HP", wall:GetAttribute("MaxHP"))
					wall:SetAttribute("Broken", false)
					wall.Transparency = 0
					wall.CanCollide = true
					updateWallText(wall)
				end
			end)
		end
	end)
end

for _, config in ipairs(wallConfigs) do
	buildWall(config)
end

local boss = makePart("Titan Server Wall", wallsFolder, Vector3.new(34, 28, 6), Vector3.new(82, 16, 27), Color3.fromRGB(38, 36, 46), Enum.Material.Slate)
boss:SetAttribute("MaxHP", 5000000)
boss:SetAttribute("HP", 5000000)
boss:SetAttribute("RequiredLevel", 20)
boss:SetAttribute("CoinReward", 450000)
boss:SetAttribute("PowerReward", 12000)
makeText(boss, "TITAN SERVER WALL", "Co-op Boss | Big Reward", Enum.NormalId.Front)
updateWallText(boss)

local bossClick = Instance.new("ClickDetector")
bossClick.MaxActivationDistance = 50
bossClick.Parent = boss
bossClick.MouseClick:Connect(function(player)
	if statValue(player, "WallLevel", 1) < 20 then
		notify(player, "Need Wall Level 20 to fight Titan Wall.", Color3.fromRGB(255, 120, 120))
		return
	end
	local now = os.clock()
	local lastHit = player:GetAttribute("LastBossHit") or 0
	if now - lastHit < 0.2 then
		return
	end
	player:SetAttribute("LastBossHit", now)

	local damage = statValue(player, "Power", 1) * statValue(player, "FistMultiplier", 1) * (1 + statValue(player, "PetMultiplier", 0)) * 1.4
	boss:SetAttribute("HP", math.max(0, boss:GetAttribute("HP") - damage))
	updateWallText(boss)
	if boss:GetAttribute("HP") <= 0 and not boss:GetAttribute("Broken") then
		boss:SetAttribute("Broken", true)
		broadcast("Titan Server Wall shattered! Everyone gets a reward.", Color3.fromRGB(120, 220, 255))
		for _, plr in ipairs(Players:GetPlayers()) do
			addStat(plr, "Coins", boss:GetAttribute("CoinReward"))
			addStat(plr, "Power", boss:GetAttribute("PowerReward"))
		end
		boss.Transparency = 0.85
		boss.CanCollide = false
		task.delay(20, function()
			if boss.Parent then
				boss:SetAttribute("HP", boss:GetAttribute("MaxHP"))
				boss:SetAttribute("Broken", false)
				boss.Transparency = 0
				boss.CanCollide = true
				updateWallText(boss)
			end
		end)
	end
end)

local trainingConfigs = {
	{ name = "Power Bag", stat = "Power", gain = 4, pos = Vector3.new(-53, 4, 24), color = Color3.fromRGB(255, 215, 90) },
	{ name = "Speed Dummy", stat = "BreakSpeed", gain = 0.02, pos = Vector3.new(-34, 4, 24), color = Color3.fromRGB(102, 194, 255) },
	{ name = "Focus Stone", stat = "CritChance", gain = 0.05, pos = Vector3.new(-15, 4, 24), color = Color3.fromRGB(190, 126, 255) },
}

for _, config in ipairs(trainingConfigs) do
	local station = makePart(config.name, interactFolder, Vector3.new(9, 8, 9), config.pos, config.color, Enum.Material.Neon)
	makeText(station, config.name, ("Click: +%s %s"):format(config.gain, config.stat), Enum.NormalId.Front)
	local detector = Instance.new("ClickDetector")
	detector.MaxActivationDistance = 32
	detector.Parent = station
	detector.MouseClick:Connect(function(player)
		local now = os.clock()
		local key = "LastTrain" .. config.stat
		local lastTrain = player:GetAttribute(key) or 0
		if now - lastTrain < TRAINING_COOLDOWN then
			return
		end
		player:SetAttribute(key, now)
		addStat(player, config.stat, config.gain)
		addStat(player, "FistMastery", 0.03)
		notify(player, ("Training: +%s %s"):format(config.gain, config.stat), Color3.fromRGB(255, 246, 155))
	end)
end

local fistShop = {
	{ name = "Boxing Glove", cost = 250, mult = 1.8, speed = 0.2 },
	{ name = "Iron Knuckle", cost = 1500, mult = 4.5, speed = 0.35 },
	{ name = "Thunder Fist", cost = 12000, mult = 13, speed = 0.7 },
	{ name = "Titan Gauntlet", cost = 125000, mult = 45, speed = 1.2 },
}

local shopBack = makePart("Fist Shop Sign", root, Vector3.new(42, 10, 2), Vector3.new(-43, 7, -3), Color3.fromRGB(24, 43, 50), Enum.Material.Metal)
makeText(shopBack, "FIST SHOP", "Click a glove stand to buy upgrades")

for index, item in ipairs(fistShop) do
	local stand = makePart(item.name .. " Stand", interactFolder, Vector3.new(9, 5, 9), Vector3.new(-65 + index * 14, 3, -10), Color3.fromRGB(230, 230, 230), Enum.Material.Metal)
	makeText(stand, item.name, ("Cost %s | x%.1f"):format(formatNumber(item.cost), item.mult), Enum.NormalId.Front)
	local detector = Instance.new("ClickDetector")
	detector.MaxActivationDistance = 30
	detector.Parent = stand
	detector.MouseClick:Connect(function(player)
		if statValue(player, "Coins", 0) < item.cost then
			notify(player, ("Need %s coins for %s."):format(formatNumber(item.cost), item.name), Color3.fromRGB(255, 120, 120))
			return
		end
		if statValue(player, "FistMultiplier", 1) >= item.mult then
			notify(player, "You already own an equal or stronger fist.", Color3.fromRGB(190, 220, 255))
			return
		end
		addStat(player, "Coins", -item.cost)
		setStat(player, "FistMultiplier", item.mult)
		addStat(player, "BreakSpeed", item.speed)
		local equipped = playerStat(player, "EquippedFist")
		if equipped then
			equipped.Value = item.name
		end
		notify(player, ("Equipped %s! Damage x%.1f"):format(item.name, item.mult), Color3.fromRGB(104, 255, 169))
	end)
end

local eggPart = makePart("Pet Egg Machine", interactFolder, Vector3.new(14, 11, 14), Vector3.new(-72, 6, 24), Color3.fromRGB(255, 180, 88), Enum.Material.Neon)
makeText(eggPart, "PET EGG", ("Cost %s coins | Luck helps"):format(EGG_COST), Enum.NormalId.Front)

local pets = {
	{ name = "Brick Pup", chance = 55, mult = 0.15, luck = 0.05 },
	{ name = "Miner Cat", chance = 30, mult = 0.35, luck = 0.12 },
	{ name = "Crystal Fox", chance = 11, mult = 0.85, luck = 0.25 },
	{ name = "Lava Dragon", chance = 3.5, mult = 1.7, luck = 0.45 },
	{ name = "Secret Titan Golem", chance = 0.5, mult = 4.5, luck = 1.2 },
}

local eggDetector = Instance.new("ClickDetector")
eggDetector.MaxActivationDistance = 32
eggDetector.Parent = eggPart
eggDetector.MouseClick:Connect(function(player)
	if statValue(player, "Coins", 0) < EGG_COST then
		notify(player, ("Need %s coins to hatch an egg."):format(EGG_COST), Color3.fromRGB(255, 120, 120))
		return
	end
	addStat(player, "Coins", -EGG_COST)

	local luck = math.max(1, statValue(player, "Luck", 1))
	local roll = math.random() * 100 / luck
	local cumulative = 0
	local chosen = pets[1]
	for _, pet in ipairs(pets) do
		cumulative += pet.chance
		if roll <= cumulative then
			chosen = pet
			break
		end
	end

	local current = statValue(player, "PetMultiplier", 0)
	if chosen.mult > current then
		setStat(player, "PetMultiplier", chosen.mult)
		local petName = playerStat(player, "Pet")
		if petName then
			petName.Value = chosen.name
		end
	end
	addStat(player, "Luck", chosen.luck)
	notify(player, ("Hatched %s! Pet power +%.0f%%"):format(chosen.name, chosen.mult * 100), Color3.fromRGB(255, 210, 95))
end)

local rebirthPart = makePart("Rebirth Shrine", interactFolder, Vector3.new(14, 13, 14), Vector3.new(160, 7, 24), Color3.fromRGB(255, 255, 255), Enum.Material.ForceField)
makeText(rebirthPart, "REBIRTH", "Need Wall Lv 55 and 1M coins")
local rebirthDetector = Instance.new("ClickDetector")
rebirthDetector.MaxActivationDistance = 35
rebirthDetector.Parent = rebirthPart
rebirthDetector.MouseClick:Connect(function(player)
	if statValue(player, "WallLevel", 1) < 55 or statValue(player, "Coins", 0) < 1000000 then
		notify(player, "Rebirth needs Wall Level 55 and 1M coins.", Color3.fromRGB(255, 120, 120))
		return
	end
	addStat(player, "Rebirths", 1)
	setStat(player, "Power", 25)
	setStat(player, "Coins", 0)
	setStat(player, "WallLevel", 1)
	setStat(player, "FistMultiplier", 1)
	setStat(player, "BreakSpeed", 1)
	local fist = playerStat(player, "EquippedFist")
	if fist then
		fist.Value = "Starter Glove"
	end
	notify(player, "Rebirth complete! Permanent +25% power multiplier.", Color3.fromRGB(140, 220, 255))
end)

for _, z in ipairs({ -44, -10, 24, 58 }) do
	makePart("Lane Stripe", root, Vector3.new(210, 0.15, 1.2), Vector3.new(48, 0.12, z), Color3.fromRGB(110, 130, 142), Enum.Material.Neon)
end

Players.PlayerAdded:Connect(ensureStats)
for _, player in ipairs(Players:GetPlayers()) do
	ensureStats(player)
end
