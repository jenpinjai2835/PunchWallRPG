        <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local ROOT_NAME = "PunchWallRPG"
local WALL_RESPAWN_SECONDS = 5
local TRAINING_COOLDOWN = 0.45
local WALL_HIT_COOLDOWN = 0.25
local EGG_COST = 350

local root = workspace:FindFirstChild(ROOT_NAME)
if root then
	root:Destroy()
end

root = Instance.new("Folder")
root.Name = ROOT_NAME
root.Parent = workspace

local remotes = ReplicatedStorage:FindFirstChild("PunchWallEvents")
if remotes then
	remotes:Destroy()
end
remotes = Instance.new("Folder")
remotes.Name = "PunchWallEvents"
remotes.Parent = ReplicatedStorage

local notifyRemote = Instance.new("RemoteEvent")
notifyRemote.Name = "Notify"
notifyRemote.Parent = remotes

local statRemote = Instance.new("RemoteEvent")
statRemote.Name = "StatsChanged"
statRemote.Parent = remotes

local wallsFolder = Instance.new("Folder")
wallsFolder.Name = "Walls"
wallsFolder.Parent = root

local interactFolder = Instance.new("Folder")
interactFolder.Name = "Interactables"
interactFolder.Parent = root

local function makePart(name, parent, size, position, color, material)
	local part = Instance.new("Part")
	part.Name = name
	part.Anchored = true
	part.Size = size
	part.Position = position
	part.Color = color
	part.Material = material or Enum.Material.SmoothPlastic
	part.TopSurface = Enum.SurfaceType.Smooth
	part.BottomSurface = Enum.SurfaceType.Smooth
	part.Parent = parent
	return part
end

local function makeText(part, title, subtitle, face)
	local surface = Instance.new("SurfaceGui")
	surface.Name = "Sign"
	surface.Face = face or Enum.NormalId.Front
	surface.SizingMode = Enum.SurfaceGuiSizingMode.PixelsPerStud
	surface.PixelsPerStud = 40
	surface.Parent = part

	local titleLabel = Instance.new("TextLabel")
	titleLabel.Name = "Title"
	titleLabel.BackgroundTransparency = 1
	titleLabel.Position = UDim2.fromScale(0.04, 0.08)
	titleLabel.Size = UDim2.fromScale(0.92, 0.38)
	titleLabel.Font = Enum.Font.GothamBlack
	titleLabel.Text = title
	titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	titleLabel.TextScaled = true
	titleLabel.TextStrokeTransparency = 0.55
	titleLabel.Parent = surface

	local subLabel = Instance.new("TextLabel")
	subLabel.Name = "Subtitle"
	subLabel.BackgroundTransparency = 1
	subLabel.Position = UDim2.fromScale(0.06, 0.48)
	subLabel.Size = UDim2.fromScale(0.88, 0.38)
	subLabel.Font = Enum.Font.GothamBold
	subLabel.Text = subtitle
	subLabel.TextColor3 = Color3.fromRGB(235, 242, 255)
	subLabel.TextScaled = true
	subLabel.TextStrokeTransparency = 0.65
	subLabel.Parent = surface

	return surface
end

local function formatNumber(value)
	local abs = math.abs(value)
	if abs >= 1e12 then
		return string.format("%.1fT", value / 1e12)
	elseif abs >= 1e9 then
		return string.format("%.1fB", value / 1e9)
	elseif abs >= 1e6 then
		return string.format("%.1fM", value / 1e6)
	elseif abs >= 1e3 then
		return string.format("%.1fK", value / 1e3)
	end
	return tostring(math.floor(value + 0.5))
end

local function playerStat(player, name)
	local stats = player:FindFirstChild("RPGStats")
	return stats and stats:FindFirstChild(name)
end

local function notify(player, message, color)
	notifyRemote:FireClient(player, message, color or Color3.fromRGB(255, 235, 140))
end

local function broadcast(message, color)
	for _, player in ipairs(Players:GetPlayers()) do
		notify(player, message, color)
	end
end

local function syncStats(player)
	local stats = player:FindFirstChild("RPGStats")
	if not stats then
		return
	end

	local payload = {}
	for _, value in ipairs(stats:GetChildren()) do
		if value:IsA("NumberValue") or value:IsA("StringValue") then
			payload[value.Name] = value.Value
		end
	end
	statRemote:FireClient(player, payload)
end

local function ensureStats(player)
	local stats = Instance.new("Folder")
	stats.Name = "RPGStats"
	stats.Parent = player

	local leaderstats = Instance.new("Folder")
	leaderstats.Name = "leaderstats"
	leaderstats.Parent = player

	local function number(name, value, parent)
		local instance = Instance.new("NumberValue")
		instance.Name = name
		instance.Value = value
		instance.Parent = parent or stats
		instance.Changed:Connect(function()
			syncStats(player)
		end)
		return instance
	end

	local function text(name, value)
		local instance = Instance.new("StringValue")
		instance.Name = name
		instance.Value = value
		instance.Parent = stats
		instance.Changed:Connect(function()
			syncStats(player)
		end)
		return instance
	end

	number("Power", 15, leaderstats)
	number("Coins", 0, leaderstats)
	number("WallLevel", 1, leaderstats)
	number("Rebirths", 0, leaderstats)

	number("FistMastery", 1)
	number("BreakSpeed", 1)
	number("CritChance", 5)
	number("Luck", 1)
	number("FistMultiplier", 1)
	number("PetMultiplier", 0)
	text("EquippedFist", "Starter Glove")
	text("Pet", "None")

	task.defer(function()
		syncStats(player)
		notify(player, "Punch Wall RPG loaded. Click bags to train, click walls to break.")
	end)
end

local function statValue(player, name, fallback)
	local value = playerStat(player, name)
	if value then
		return value.Value
	end
	local leaderstats = player:FindFirstChild("leaderstats")
	value = leaderstats and leaderstats:FindFirstChild(name)
	if value then
		return value.Value
	end
	return fallback or 0
end

local function setStat(player, name, amount)
	local value = playerStat(player, name)
	if not value then
		local leaderstats = player:FindFirstChild("leaderstats")
		value = leaderstats and leaderstats:FindFirstChild(name)
	end
	if value then
		value.Value = amount
	end
end

local function addStat(player, name, amount)
	setStat(player, name, statValue(player, name) + amount)
end

local base = makePart("Main Training Island", root, Vector3.new(210, 3, 96), Vector3.new(48, -1.5, 0), Color3.fromRGB(75, 94, 106), Enum.Material.Concrete)
base.Locked = true

makePart("Spawn Pad", root, Vector3.new(18, 1, 18), Vector3.new(-42, 1, 0), Color3.fromRGB(94, 220, 160), Enum.Material.Neon)
local spawn = Instance.new("SpawnLocation")
spawn.Name = "Punch Rookie Spawn"
spawn.Anchored = true
spawn.Size = Vector3.new(10, 1, 10)
spawn.Position = Vector3.new(-42, 2, 0)
spawn.Color = Color3.fromRGB(105, 232, 167)
spawn.Material = Enum.Material.Neon
spawn.Neutral = true
spawn.Parent = root

local arch = makePart("Prototype Title Sign", root, Vector3.new(42, 14, 2), Vector3.new(-44, 9, -25), Color3.fromRGB(30, 42, 58), Enum.Material.Metal)
makeText(arch, "PUNCH WALL RPG", "Train > Break > Hatch Pets > Rebirth")

local wallConfigs = {
	{
		name = "Brick Wall",
		hp = 120,
		level = 1,
		coins = 45,
