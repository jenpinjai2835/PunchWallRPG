	subLabel.Text = subtitle
	subLabel.TextColor3 = Color3.fromRGB(235, 242, 255)
	subLabel.TextScaled = true
	subLabel.TextStrokeTransparency = 0.65
	subLabel.Parent = surface

	return surface
end

