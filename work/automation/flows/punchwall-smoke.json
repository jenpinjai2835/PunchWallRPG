{
  "name": "punchwall-smoke",
  "description": "Existing smoke flow for the Punch Wall RPG prototype.",
  "studioName": "PunchWallRPGPlayable_v1_final.rbxlx",
  "pollAttempts": 15,
  "pollMs": 3000,
  "steps": [
    {
      "type": "call",
      "tool": "get_studio_state",
      "saveAs": "stateBefore",
      "expectRegex": [
        "Current Studio Mode:\\s*Edit"
      ],
      "label": "edit mode detected"
    },
    {
      "type": "call",
      "tool": "search_game_tree",
      "args": {
        "path": "Workspace.PunchWallRPG",
        "max_depth": 3,
        "head_limit": 120
      },
      "saveAs": "editTree",
      "label": "capture edit preview tree"
    },
    {
      "type": "assertTreeNames",
      "source": "editTree",
      "parentName": "PunchWallRPG",
      "names": [
        "Preview Walls",
        "Preview Interactables"
      ],
      "label": "edit preview folders detected"
    },
    {
      "type": "call",
      "tool": "start_stop_play",
      "args": {
        "is_start": true
      },
      "timeoutMs": 35000,
      "label": "start play"
    },
    {
      "type": "wait",
      "ms": 6000,
      "label": "wait for runtime bootstrap"
    },
    {
      "type": "call",
      "tool": "get_studio_state",
      "saveAs": "statePlay",
      "expectRegex": [
        "Current Studio Mode:\\s*Play",
        "Available DataModels:\\s*Client,\\s*Server"
      ],
      "label": "play mode detected"
    },
    {
      "type": "call",
      "tool": "execute_luau",
      "args": {
        "datamodel_type": "Server",
        "code": "local H=game:GetService('HttpService') local r=workspace.PunchWallRPG local w=r.Walls local d=r['Depth Blocks'] local i=r.Interactables local required={'Power Bag','Pet Egg Machine','Rebirth Shrine','Hero Armory Merchant Interaction','Hero Sidekick Scientist Interaction','Honor Keeper Interaction'} local found=0 for _,n in ipairs(required) do if i:FindFirstChild(n) then found+=1 end end return H:JSONEncode({walls=#w:GetChildren(),depthBlocks=#d:GetChildren(),interactables=#i:GetChildren(),requiredInteractables=found,powerOnly=i:FindFirstChild('Speed Dummy')==nil and i:FindFirstChild('Focus Stone')==nil,titan=w:FindFirstChild('Titan Server Wall')~=nil})"
      },
      "expectRegex": [
        "\"walls\"[ ]*:[ ]*[1-9][0-9]*",
        "\"depthBlocks\"[ ]*:[ ]*5400",
        "\"interactables\"[ ]*:[ ]*[9-9][0-9]*|\"interactables\"[ ]*:[ ]*[1-9][0-9]+",
        "\"requiredInteractables\"[ ]*:[ ]*6",
        "\"powerOnly\"[ ]*:[ ]*true",
        "\"titan\"[ ]*:[ ]*true"
      ],
      "label": "runtime folders and key objects detected"
    },
    {
      "type": "call",
      "tool": "inspect_instance",
      "args": {
        "path": "Workspace.PunchWallRPG.Depth Blocks.DepthBlock_L001_C06_R02"
      },
      "saveAs": "brickWall",
      "expectRegex": [
        "\"MaxHP\"\\s*:\\s*8",
        "\"IsDepthBlock\"\\s*:\\s*true",
        "\"Tier\"\\s*:\\s*1"
      ],
      "label": "front excavation block attributes"
    },
    {
      "type": "call",
      "tool": "inspect_instance",
      "args": {
        "path": "Workspace.PunchWallRPG.Walls.Titan Server Wall"
      },
      "saveAs": "titanWall",
      "expectRegex": [
        "\"MaxHP\"\\s*:\\s*800000000",
        "ClickDetector"
      ],
      "label": "titan wall attributes"
    },
    {
      "type": "call",
      "tool": "get_console_output",
      "saveAs": "console",
      "label": "capture console"
    },
    {
      "type": "assertNoConsoleErrors",
      "source": "console",
      "label": "console clean"
    },
    {
      "type": "call",
      "tool": "start_stop_play",
      "args": {
        "is_start": false
      },
      "timeoutMs": 35000,
      "label": "stop play"
    }
  ],
  "cleanup": [
    {
      "type": "call",
      "tool": "start_stop_play",
      "args": {
        "is_start": false
      },
      "timeoutMs": 35000,
      "allowError": true,
      "label": "cleanup stop play"
    }
  ]
}
